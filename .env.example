# Copy this file to .env and fill in your values

# Hugging Face token for downloading models (required for gated models)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CivitAI API token for downloading models from CivitAI
CIVITAI_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Transformer Configuration ---
# OPTION 1: Default Flux2 Klein 9B (bfloat16)
CIVITAI_MODEL_VERSION_ID=2746781
TRANSFORMER_PATH=./models/transformer.safetensors
TRANSFORMER_DTYPE=bfloat16

# OPTION 2: Flux2 Klein 9B FP8 Quantized (8GB VRAM)
# https://civitai.com/api/download/models/2759272
# Uncomment the following three lines (and comment out Option 1) to use:
# CIVITAI_MODEL_VERSION_ID=2759272
# TRANSFORMER_PATH=./models/transformer_fp8.safetensors
# TRANSFORMER_DTYPE=fp8
# -----------------------------------

# --- Text Encoder Configuration ---
# OPTION 1: Standard Text-Only Qwen3 Encoder
TEXT_ENCODER_ID=huihui-ai/Huihui-Qwen3-8B-abliterated-v2

# OPTION 2: Qwen3-VL 8B GGUF Encoder (Saves space and VRAM)
# Uncomment the following three lines (and comment out Option 1) to use:
# TEXT_ENCODER_ID=mradermacher/nsfwvision-qwen3-vl-8b-v3-safetensors-GGUF
# TEXT_ENCODER_GGUF_FILE=nsfwvision-qwen3-vl-8b-v3-safetensors.Q8_0.gguf
# TEXT_ENCODER_TOKENIZER_ID=Qwen/Qwen2.5-VL-7B-Instruct
# -----------------------------------

# Official Flux2 repo for VAE and scheduler configs
FLUX2_REPO_ID=black-forest-labs/FLUX.2-klein-9B

# Output directory for generated images
OUTPUT_DIR=./outputs

# LoRA directory (place your LoRA .safetensors files here)
LORA_DIR=./loras

# Startup behavior
# Keep downloads disabled by default so local development never pulls large assets unexpectedly.
AUTO_INITIALIZE_PIPELINE=true
ALLOW_MODEL_DOWNLOADS=false
ENABLE_MOCK_GENERATION=false

# Low VRAM mode: enables sequential CPU offload (required for GPUs with ≤16GB like T4)
# Use with FP8 Transformer + GGUF Text Encoder for best results on T4
LOW_VRAM_MODE=false

# Generation defaults shown in the UI
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
DEFAULT_STEPS=4
DEFAULT_GUIDANCE_SCALE=1.0
DEFAULT_SEED=-1
DEFAULT_NUM_IMAGES=1
QUALITY_PRESET_MEGAPIXELS=0.5,1,1.5,2,3,4

# Server settings
HOST=0.0.0.0
PORT=8080
